# OCI API credentials
OCI_USER=ocid1.user.oc1..xxxxxxxxxxxx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_TENANCY=ocid1.tenancy.oc1..xxxxxxxxxxxx
OCI_REGION=eu-zurich-1
OCI_KEY_FILE=/home/ubuntu/.oci/oci_api_key.pem

# Instance parameters
COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxxxx
SUBNET_ID=ocid1.subnet.oc1.eu-zurich-1.xxxxxxxxxxxx
IMAGE_ID=ocid1.image.oc1.eu-zurich-1.xxxxxxxxxxxx
AVAILABILITY_DOMAIN=qKXO:EU-ZURICH-1-AD-1
INSTANCE_NAME=arm-instance
SHAPE=VM.Standard.A1.Flex
OCPUS=4
MEMORY_GB=24

# SSH public key (generated on this server)
SSH_PUBLIC_KEY_PATH=/home/ubuntu/.ssh/oracle_arm_key.pub

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# Polling
POLL_INTERVAL=30
